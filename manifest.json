{
    "manifest_version": 3,
    "name": "OSM iD: Custom Layers & Comment Suggester",
    "version": "1.50",
    "description": "An extension to let you easily choose from multiple custom layers and suggest changeset comments",
    "permissions": [
        "storage"   
    ],
    "host_permissions": [
        "https://nominatim.openstreetmap.org/*"
    ],	
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
      "matches": ["https://www.openstreetmap.org/edit*", "https://www.openstreetmap.org/id"],
      "js": ["content.js"],
      "all_frames": true  
        }
    ],
    "icons": {
        "48": "icon.png"
    }
}
